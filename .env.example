# Copy to .env and adjust as needed.

# Ollama model used for the Krish companion (fine-tuned krish voice; see finetune/Modelfile).
OLLAMA_MODEL=krish

# Your name — Krish addresses you by this.
USER_NAME=Sayee

# Ollama server endpoint.
OLLAMA_HOST=http://localhost:11434

# Backend API server.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ChromaDB persistence directory for the Bhagavad Gita RAG index.
CHROMA_DIR=chroma_db
